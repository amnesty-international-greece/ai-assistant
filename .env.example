# LLM — set the key for whichever provider is active in config.yaml
# Gemini (free tier — current default for prototyping)
GEMINI_API_KEY=

# Anthropic Claude (production — switch llm.provider to "claude" in config.yaml)
ANTHROPIC_API_KEY=

# Microsoft Graph (Azure AD)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback

# Google Cloud
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=

# Zoom
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# Per-app "Secret Token" (Event Subscriptions) — validates incoming webhooks
# such as recording.completed. Optional until the recording webhook is wired.
ZOOM_WEBHOOK_SECRET_TOKEN=

# Brevo
BREVO_API_KEY=

# Discord
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
GMAIL_APP_PASSWORD=

# App
APP_ENV=development
LOG_LEVEL=INFO
